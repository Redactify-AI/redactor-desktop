{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Redactify",
  "version": "1.0.0",
  "identifier": "com.redactify.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Redactify Workspace",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src 'self' asset: http://asset.localhost https://asset.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "**/*", "$TEMP/**", "?://**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../engine/dist/cli.exe",
      "../engine/ffmpeg.exe"
    ]
  }
}
